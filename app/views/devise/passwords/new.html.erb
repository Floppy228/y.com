<% content_for :title, "Восстановление пароля | Y.com" %>

<% content_for :styles do %>
  <%= stylesheet_link_tag "ui/auth" %>
<% end %>

<div class="auth-container">
  <div class="auth-brand">
    <div class="brand-content">
      <div class="brand-logo">Y</div>
      <h1 class="brand-title">Y.com</h1>
      <p class="brand-subtitle">Восстановление доступа к вашему аккаунту</p>

      <div class="brand-features">
        <div class="feature-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 12h18"/>
            <path d="M12 3v18"/>
          </svg>
          <span>Ссылка приходит на ваш email</span>
        </div>

        <div class="feature-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2l8 4v6c0 5.55-3.84 10.74-8 12-4.16-1.26-8-6.45-8-12V6l8-4z"/>
          </svg>
          <span>Безопасный одноразовый токен</span>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-forms">
    <div class="forms-container password-forms-container">
      <div class="auth-form-stack password-form-stack">
        <div class="auth-form active password-form">
          <h2 class="form-title">Забыли пароль?</h2>
          <p class="form-subtitle">Введите email, и мы отправим ссылку для смены пароля.</p>

          <% if resource.errors.any? %>
            <div class="password-errors">
              <% resource.errors.full_messages.each do |message| %>
                <p><%= message %></p>
              <% end %>
            </div>
          <% end %>

          <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, novalidate: true }) do |f| %>
            <div class="input-group">
              <label class="input-label">Email</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
                  <path d="M22 6L12 13 2 6"/>
                </svg>
                <%= f.email_field :email,
                      class: "input-field",
                      autofocus: true,
                      autocomplete: "email",
                      placeholder: "your@email.com",
                      required: true %>
              </div>
            </div>

            <button class="btn-submit" type="submit">
              <span>Отправить ссылку</span>
              <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14"/>
                <path d="M12 5l7 7-7 7"/>
              </svg>
            </button>
          <% end %>

          <div class="form-options form-options-single">
            <%= link_to "Вернуться ко входу", new_user_session_path, class: "forgot-link" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

