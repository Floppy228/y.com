
<% content_for :title, "Y-Core | Y.com" %>

<% content_for :styles do %>
  <%= stylesheet_link_tag "ui/ai" %>
<% end %>

<div class="layout">
    <!-- Левая панель с SVG-иконками -->
    <aside class="sidebar-left">
        <a href="/" class="logo">Y.com</a>
        <nav class="nav-group">
            <a href="/" class="nav-item">
                <svg viewBox="0 0 24 24">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                Главная
            </a>
            <a href="/profile" class="nav-item">
                <svg viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                Профиль
            </a>
            <a href="/messages" class="nav-item">
                <svg viewBox="0 0 24 24">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                Сообщения
            </a>
            <a href="/ai" class="nav-item active">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 8v8M8 12h8"/>
                    <path d="M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z"/>
                </svg>
                Y-Core
            </a>
            <a href="/following" class="nav-item">
                <svg viewBox="0 0 24 24">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                Подписки
            </a>
            <a href="/settings" class="nav-item">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H5.78a1.65 1.65 0 0 0-1.51 1 1.65 1.65 0 0 0 .33 1.82l.07.08A10 10 0 0 0 12 17.66a10 10 0 0 0 6.26-2.58z"/>
                    <path d="M16.5 6.5L19 9l-2.5 2.5"/>
                    <path d="M7.5 6.5L5 9l2.5 2.5"/>
                </svg>
                Настройки
            </a>
                </nav>
        <% if user_signed_in? %>
          <%= button_to destroy_user_session_path, method: :delete, class: "btn-main", form_class: "logout-form" do %>
              <svg viewBox="0 0 24 24">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                  <polyline points="16 17 21 12 16 7"/>
                  <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
              Выйти
          <% end %>
        <% end %>
        <button class="btn-main" id="newChatBtn">
            <svg viewBox="0 0 24 24">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Новый диалог
        </button>
    </aside>

    <!-- Центральная колонка -->
    <main class="content ai-layout">
        <div class="ai-container" id="aiContainer">
            
            <!-- Приветственный экран -->
            <div class="ai-welcome" id="welcomeScreen">
                <div class="ai-logo-anim">Y</div>
                <h1>Чем я могу помочь?</h1>
                
                <div class="ai-suggestions">
                    <div class="suggest-card">Проанализируй рынок криптовалют</div>
                    <div class="suggest-card">Напиши смарт-контракт на Solidity</div>
                    <div class="suggest-card">Объясни теорию струн</div>
                    <div class="suggest-card">Сгенерируй идеи для стартапа</div>
                    <div class="suggest-card">Оптимизируй код на Python</div>
                    <div class="suggest-card">Создай структуру базы данных</div>
                </div>
            </div>

            <!-- Область чата -->
            <div class="ai-response-area" id="responseArea"></div>

            <!-- Поле ввода -->
            <div class="ai-input-section">
                <div class="ai-input-wrapper">
                    <textarea id="aiInput" placeholder="Спроси Y-Core..." rows="1"></textarea>
                    
                    <div class="ai-input-controls">
                        <div class="ai-tools-left">
                            <div class="tool-icon" id="attachFile" title="Прикрепить файл">
                                <svg viewBox="0 0 24 24">
                                    <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
                                </svg>
                            </div>
                            <div class="tool-icon" id="webSearch" title="Поиск в интернете">
                                <svg viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10"/>
                                    <line x1="2" y1="12" x2="22" y2="12"/>
                                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                                </svg>
                            </div>
                            <div class="tool-icon" id="clearChat" title="Очистить историю">
                                <svg viewBox="0 0 24 24">
                                    <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                    <line x1="10" y1="11" x2="10" y2="17"/>
                                    <line x1="14" y1="11" x2="14" y2="17"/>
                                </svg>
                            </div>
                        </div>

                        <button class="btn-send-main" id="sendBtn" disabled>
                            <svg viewBox="0 0 24 24">
                                <line x1="22" y1="2" x2="11" y2="13"/>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div style="text-align: right; margin-top: 8px; color: var(--text-secondary); font-size: 12px;">
                    Y-Core может ошибаться. Проверяйте важную информацию.
                </div>
            </div>
        </div>
    </main>

    <!-- Правая панель -->
    <aside class="sidebar-right">
        <div class="search-container">
            <input type="text" placeholder="Поиск в истории" id="searchHistory">
        </div>
        <div class="panel">
            <h3>Возможности Y-Core</h3>
            <div class="ai-capability">
                <svg viewBox="0 0 24 24">
                    <path d="M12 2v4M12 22v-4M4 12H2h2M22 12h-2M19.07 4.93l-2.83 2.83M4.93 19.07l2.83-2.83M19.07 19.07l-2.83-2.83M4.93 4.93l2.83 2.83"/>
                </svg>
                <span>Анализ данных</span>
            </div>
            <div class="ai-capability">
                <svg viewBox="0 0 24 24">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
                <span>Написание кода</span>
            </div>
            <div class="ai-capability">
                <svg viewBox="0 0 24 24">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <circle cx="12" cy="12" r="3"/>
                </svg>
                <span>Шифрование</span>
            </div>
        </div>
        <div class="panel">
            <h3>Актуальное</h3>
            <div class="trend-row">
                <span class="trend-tag">#AI</span>
                <div class="trend-title">Новая модель Y-Core</div>
            </div>
            <div class="trend-row">
                <span class="trend-tag">#Update</span>
                <div class="trend-title">Улучшенная обработка</div>
            </div>
        </div>
    </aside>
</div>



