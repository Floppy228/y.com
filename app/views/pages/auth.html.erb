<% requested_mode = params[:auth_mode].presence || @auth_mode.presence %>
<% auth_mode = requested_mode.to_s == "register" ? "register" : "login" %>
<% login_active = auth_mode != "register" %>
<% register_active = auth_mode == "register" %>

<% content_for :title, "#{register_active ? 'Регистрация' : 'Вход'} | Y.com" %>

<% content_for :styles do %>
  <%= stylesheet_link_tag "ui/auth" %>
<% end %>

<div class="auth-container">
  <div class="auth-brand">
    <div class="brand-content">
      <div class="brand-logo">Y</div>
      <h1 class="brand-title">Y.com</h1>
      <p class="brand-subtitle">Знать обо всем</p>

      <div class="brand-features">
        <div class="feature-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <span>Только важные контакты</span>
        </div>

        <div class="feature-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            <path d="M8 10h.01"/>
            <path d="M12 10h.01"/>
            <path d="M16 10h.01"/>
          </svg>
          <span>Чистый минимализм</span>
        </div>

        <div class="feature-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 8v8"/>
            <path d="M8 12h8"/>
            <path d="M12 2a15 15 0 0 1 0 20 15 15 0 0 1 0-20z"/>
          </svg>
          <span>AI-помощник Y-Core</span>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-forms">
    <div class="forms-container">
      <div class="auth-toggle">
        <%= link_to "Вход", new_user_session_path, class: "auth-toggle-btn #{'active' if login_active}" %>
        <%= link_to "Регистрация", new_user_session_path(auth_mode: "register"), class: "auth-toggle-btn #{'active' if register_active}" %>
      </div>

      <div class="auth-form-stack">
        <div class="auth-form <%= 'active' if login_active %>" id="loginForm">
          <h2 class="form-title">Добро пожаловать!</h2>
          <p class="form-subtitle">Войдите в свой аккаунт Y.com</p>

          <%= form_for(User.new, as: :user, url: user_session_path, html: { novalidate: true }) do |f| %>
            <%= hidden_field_tag :auth_mode, "login" %>

            <div class="input-group">
              <label class="input-label">Email</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
                  <path d="M22 6L12 13 2 6"/>
                </svg>
                <%= f.email_field :email,
                      class: "input-field",
                      id: "loginEmail",
                      placeholder: "your@email.com",
                      autocomplete: "email",
                      required: true %>
              </div>
            </div>

            <div class="input-group">
              <label class="input-label">Пароль</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <%= f.password_field :password,
                      class: "input-field",
                      id: "loginPassword",
                      placeholder: "••••••••",
                      autocomplete: "current-password",
                      required: true %>
                <button class="toggle-password" type="button" data-password-toggle="loginPassword" aria-label="Показать пароль" aria-pressed="false">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="form-options">
              <label class="checkbox-label">
                <%= f.check_box :remember_me %>
                <span class="checkbox-custom"></span>
                <span>Запомнить меня</span>
              </label>

              <%= link_to "Забыли пароль?", new_user_password_path, class: "forgot-link" %>
            </div>

            <button class="btn-submit" type="submit" id="loginBtn">
              <span>Войти</span>
              <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14"/>
                <path d="M12 5l7 7-7 7"/>
              </svg>
            </button>
          <% end %>

        </div>

        <div class="auth-form <%= 'active' if register_active %>" id="registerForm">
          <h2 class="form-title">Создать аккаунт</h2>
          <p class="form-subtitle">Присоединяйтесь к Y.com</p>

          <%= form_for(User.new, as: :user, url: user_registration_path, html: { novalidate: true }) do |f| %>
            <%= hidden_field_tag :auth_mode, "register" %>

            <div class="input-group">
              <label class="input-label">Имя</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <%= f.text_field :name,
                      class: "input-field",
                      id: "registerName",
                      placeholder: "Алексей Морозов",
                      required: true %>
              </div>
            </div>

            <div class="input-group">
              <label class="input-label">Username</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                <%= f.text_field :username,
                      class: "input-field",
                      placeholder: "alex_morozov",
                      required: true %>
              </div>
            </div>

            <div class="input-group">
              <label class="input-label">Email</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="4" width="20" height="16" rx="2" ry="2"/>
                  <path d="M22 6L12 13 2 6"/>
                </svg>
                <%= f.email_field :email,
                      class: "input-field",
                      id: "registerEmail",
                      placeholder: "your@email.com",
                      autocomplete: "email",
                      required: true %>
              </div>
            </div>

            <div class="input-group">
              <label class="input-label">Пароль</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <%= f.password_field :password,
                      class: "input-field",
                      id: "registerPassword",
                      placeholder: "••••••••",
                      autocomplete: "new-password",
                      required: true %>
                <button class="toggle-password" type="button" data-password-toggle="registerPassword" aria-label="Показать пароль" aria-pressed="false">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="input-group">
              <label class="input-label">Подтвердите пароль</label>
              <div class="input-wrapper">
                <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <%= f.password_field :password_confirmation,
                      class: "input-field",
                      id: "registerConfirm",
                      placeholder: "••••••••",
                      autocomplete: "new-password",
                      required: true %>
                <button class="toggle-password" type="button" data-password-toggle="registerConfirm" aria-label="Показать пароль" aria-pressed="false">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                    <circle cx="12" cy="12" r="3"/>
                  </svg>
                </button>
              </div>
            </div>

            <div class="form-options">
              <label class="checkbox-label">
                <%= check_box_tag :terms_check, "1", false, id: "termsCheck", required: true %>
                <span class="checkbox-custom"></span>
                <span>Я принимаю условия</span>
              </label>
            </div>

            <button class="btn-submit" type="submit" id="registerBtn">
              <span>Зарегистрироваться</span>
              <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14"/>
                <path d="M12 5l7 7-7 7"/>
              </svg>
            </button>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const openEyeIcon = `
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
      <circle cx="12" cy="12" r="3"/>
    `;

    const closedEyeIcon = `
      <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
      <line x1="1" y1="1" x2="23" y2="23"/>
    `;

    document.querySelectorAll('[data-password-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const inputId = btn.getAttribute('data-password-toggle');
        const input = document.getElementById(inputId);
        if (!input) return;

        const showing = input.type === 'password';
        input.type = showing ? 'text' : 'password';

        const svg = btn.querySelector('svg');
        if (svg) {
          svg.innerHTML = showing ? closedEyeIcon : openEyeIcon;
        }

        btn.setAttribute('aria-pressed', showing ? 'true' : 'false');
        btn.setAttribute('aria-label', showing ? 'Скрыть пароль' : 'Показать пароль');
      });
    });
  });
</script>
